// =====================================================
//  MapSolve — حل المسار باستخدام مكتبة Robotrick
//
//  اكتب المسار مثل وصفة: حركة ورا حركة.
//  كل القيم (بنات/سرعات/معايرة) موجودة في Robotrick.h
// =====================================================
#include <Robotrick.h>

Robotrick bot;

void setup() {
    bot.begin();          // init + معايرة الجايرو (ثبّت الروبوت)
    delay(1000);

    // ── المسار ─────────────────────────────────────
    bot.turnLeft(90);
    bot.forward(30);
    bot.turnLeft(90);
    bot.forward(50);

    bot.stop();           // خلص
}

void loop() {
    // كل شي بالـ setup — ما في تكرار
}
